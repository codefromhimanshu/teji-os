# Copy to os.env (gitignored) and fill in.
# Slack incoming webhook for #company-os — create at https://api.slack.com/apps
# (Your Apps -> Create -> Incoming Webhooks -> Add New Webhook to Workspace)
SLACK_WEBHOOK_URL=

# Slack MCP (read channels + post messages from Claude Code).
# Create a Slack app at https://api.slack.com/apps, add a Bot Token (xoxb-...) with at minimum
# the OAuth scopes: channels:read, chat:write, users:read, channels:history, groups:read.
# Install the app to the workspace and copy the Bot User OAuth Token below.
# SLACK_TEAM_ID is the workspace ID (looks like T0123ABCD) — find it in Slack URL or via api.slack.com.
# These are read by ~/infinite/.mcp.json when launching the slack MCP server.
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=

# Founder emails for the weekly Gmail digest
FOUNDER_EMAIL_1=himanshujain.2792@gmail.com
FOUNDER_EMAIL_2=
